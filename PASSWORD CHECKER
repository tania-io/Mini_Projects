
print("Could your Password protect your privacy?👾 \nTo Verify, follow here 🪛")
print("📝We Rate:\nStrong Password! 🎯 \nGood Password! 🛠️ \nSatisfactory Password! 🔒 \nWeak Password! ⛓️‍💥 \nUnsatisfactory!")

userName = input("🪪 Enter your Username: ")

while True:

    userPassword = input("🥷 Enter your Password: ")

    name_part = ""

    for char in userName:
        if char.isalpha():
            name_part += char
        else:
            break

    has_digit, has_upper, has_lower, has_special = False, False, False, False

    contains_username = (
        len(name_part) >= 3
        and name_part.lower() in userPassword.lower()
    )

    for char in userPassword:
        if char.isdigit():
            has_digit = True

        if char.isupper():
            has_upper = True

        if char.islower():
            has_lower = True

        if not char.isalnum() and char != " ":
            has_special = True

    if has_digit:
        print("🧮 Found Number!")
    else:
        print("❌ No Number Found!")

    if has_upper:
        print("🔠 Found Upper!")
    else:
        print("❌ No Upper Found!")

    if has_lower:
        print("🔡 Found Lower!")
    else:
        print("❌ No Lower Found!")

    if has_special:
        print("🔣 Found Special Character!")
    else:
        print("❌ No Special Character Found!")


    if userPassword.strip() == "":
        print("Password cannot be empty or only spaces ❓❓")
        continue


    if len(userPassword) < 8:

        print("Your password must be at least 8 characters long. ⛓️")

    else:
        score = (
            has_digit
            + has_upper
            + has_lower
            + has_special
        )

        if contains_username:  # deduction of 1
            score -= 1
            print("⚠️ Password contains your Username.")

        if score == 4:
            print("Strong Password! 🎯")

        elif score == 3:
            print("Good Password! 🛠️")

        elif score == 2:
            print("Satisfactory Password! 🔒")

        elif score == 1:
            print("Weak Password! ⛓️‍💥")

        else:
            print("Unsatisfactory! You need to upgrade your password! 📛")
